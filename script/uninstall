#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
PRIMARY_CONFIG_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/pm-skills/config.yml"
FALLBACK_CONFIG_PATH="$HOME/.pm-skills/config.yml"
LEGACY_CONFIG_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/pm-skills/profile.md"
LEGACY_CLAUDE_PROFILE_PATH="$HOME/.claude/pm-claude-skills.local.md"
CLAUDE_COMMANDS_TARGET="$HOME/.claude/commands"
CLAUDE_SKILLS_TARGET="$HOME/.claude/skills"
CODEX_SKILLS_TARGET="$HOME/.codex/skills"
LEGACY_CODEX_NAMESPACE="$HOME/.codex/skills/pm-skills"
LEGACY_CLAUDE_PLUGIN_NAME="pm-claude-skills"
MANAGED_COMMENT="<!-- managed-by: pm-skills repo=irishbryan/pm-skills -->"
LEGACY_MANAGED_COMMENT="<!-- managed-by: pm-skills -->"
REMOVED_LINES=()
CONFIG_LINES=()

display_path() {
  case "$1" in
    "$HOME") printf '~\n' ;;
    "$HOME"/*) printf '~/%s\n' "${1#"$HOME"/}" ;;
    *) printf '%s\n' "$1" ;;
  esac
}

add_removed_line() {
  REMOVED_LINES+=("$1")
}

add_config_line() {
  CONFIG_LINES+=("$1")
}

canonical_path() {
  local path="$1"
  if [ -d "$path" ]; then
    (cd "$path" && pwd -P)
  else
    (cd "$(dirname "$path")" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$path")")
  fi
}

resolve_link_target() {
  local link_path="$1" raw_target="" combined_path=""
  raw_target="$(readlink "$link_path")" || return 1
  if [[ "$raw_target" = /* ]]; then
    if [ -e "$raw_target" ]; then
      canonical_path "$raw_target"
    else
      printf '%s\n' "$raw_target"
    fi
  else
    combined_path="$(cd "$(dirname "$link_path")" && pwd -P)/$raw_target"
    if [ -e "$combined_path" ]; then
      canonical_path "$combined_path"
    else
      printf '%s\n' "$combined_path"
    fi
  fi
}

is_managed_command_file() {
  if [ ! -f "$1" ]; then
    return 1
  fi

  if grep -Fxq "$MANAGED_COMMENT" "$1"; then
    return 0
  fi

  grep -Fxq "$LEGACY_MANAGED_COMMENT" "$1" && is_legacy_repo_command_file "$1"
}

is_owned_command_target() {
  local path="$1" filename="$2"
  [ "$path" = "$REPO_DIR/adapters/claude/commands/$filename" ]
}

is_owned_skill_target() {
  local path="$1" skill="$2"
  case "$path" in
    "$REPO_DIR/skills/$skill") return 0 ;;
    "$REPO_DIR/adapters/claude/skills/$skill") return 0 ;;
    "$REPO_DIR/plugins/pm-skills/skills/$skill") return 0 ;;
    "$REPO_DIR/adapters/codex/pm-skills/$skill") return 0 ;;
    *) return 1 ;;
  esac
}

remove_legacy_codex_namespace_if_owned() {
  local current_target=""
  if [ -L "$LEGACY_CODEX_NAMESPACE" ]; then
    current_target="$(resolve_link_target "$LEGACY_CODEX_NAMESPACE")"
    case "$current_target" in
      "$REPO_DIR/adapters/codex/pm-skills")
        rm "$LEGACY_CODEX_NAMESPACE"
        add_removed_line "  OK   $(display_path "$LEGACY_CODEX_NAMESPACE")"
        ;;
    esac
  fi
}

remove_legacy_claude_plugin_if_present() {
  if ! command -v claude >/dev/null 2>&1; then
    return
  fi

  if claude plugin list 2>/dev/null | grep -q "^$LEGACY_CLAUDE_PLUGIN_NAME "; then
    claude plugin uninstall "$LEGACY_CLAUDE_PLUGIN_NAME" >/dev/null 2>&1 || true
    claude plugin marketplace remove "$LEGACY_CLAUDE_PLUGIN_NAME" >/dev/null 2>&1 || true
    add_removed_line "  OK   legacy Claude plugin $LEGACY_CLAUDE_PLUGIN_NAME"
  fi
}

is_legacy_repo_command_file() {
  local path="$1" base_name="" skill=""
  base_name="$(basename "$path")"

  if [ "$base_name" = "pm-skills.md" ]; then
    grep -Fq 'Browse the installed pm-skills commands.' "$path" ||
      grep -Fq 'Use the `pm-skills` skill for this request.' "$path" ||
      grep -Fq 'Route this request to one of these installed skills' "$path"
    return
  fi

  case "$base_name" in
    pm-skills:*.md)
      skill="${base_name#pm-skills:}"
      skill="${skill%.md}"
      grep -Fq "Use the installed \`pm-skills-$skill\` skill for this request." "$path" ||
        grep -Fq "Use the \`$skill\` workflow for this request." "$path"
      ;;
    *)
      return 1
      ;;
  esac
}

remove_command() {
  local path="$1" current_target=""
  if [ -f "$path" ] && is_managed_command_file "$path"; then
    rm "$path"
    add_removed_line "  OK   $(display_path "$path")"
  elif [ -L "$path" ]; then
    current_target="$(resolve_link_target "$path")"
    if is_owned_command_target "$current_target" "$(basename "$path")"; then
      rm "$path"
      add_removed_line "  OK   $(display_path "$path")"
    fi
  fi
}

remove_skill_link() {
  local path="$1" skill_name="" current_target=""
  case "$path" in
    */pm-skills:*)
      skill_name="${path##*/pm-skills:}"
      ;;
    */pm-skills-*)
      skill_name="${path##*/pm-skills-}"
      ;;
    *)
      return
      ;;
  esac
  if [ -L "$path" ]; then
    current_target="$(resolve_link_target "$path")"
    if is_owned_skill_target "$current_target" "$skill_name"; then
      rm "$path"
      add_removed_line "  OK   $(display_path "$path")"
    fi
  fi
}

remove_local_configs() {
  local reply="" removed_any="false"

  if [ ! -f "$PRIMARY_CONFIG_PATH" ] && [ ! -f "$FALLBACK_CONFIG_PATH" ] && [ ! -f "$LEGACY_CONFIG_PATH" ] && [ ! -f "$LEGACY_CLAUDE_PROFILE_PATH" ]; then
    return
  fi

  read -r -p "Remove local config too? [y/N]: " reply || exit 130
  if [[ ! "$reply" =~ ^[Yy] ]]; then
    add_config_line "  Kept local config files"
    return
  fi

  for path in "$PRIMARY_CONFIG_PATH" "$FALLBACK_CONFIG_PATH" "$LEGACY_CONFIG_PATH" "$LEGACY_CLAUDE_PROFILE_PATH"; do
    if [ -f "$path" ]; then
      rm "$path"
      add_config_line "  OK   $(display_path "$path")"
      removed_any="true"
    fi
  done

  if [ "$removed_any" = "true" ]; then
    rmdir "$(dirname "$PRIMARY_CONFIG_PATH")" 2>/dev/null || true
    rmdir "$(dirname "$FALLBACK_CONFIG_PATH")" 2>/dev/null || true
  fi
}

main() {
  local path=""

  echo '╭────────────────────────────╮'
  echo '│         pm-skills          │'
  echo '╰────────────────────────────╯'
  echo ""

  while IFS= read -r path; do
    remove_command "$path"
  done < <(find "$CLAUDE_COMMANDS_TARGET" -maxdepth 1 \( -name 'pm-skills.md' -o -name 'pm-skills:*.md' \) 2>/dev/null | sort)

  while IFS= read -r path; do
    remove_skill_link "$path"
  done < <(find "$CLAUDE_SKILLS_TARGET" -maxdepth 1 -type l \( -name 'pm-skills:*' -o -name 'pm-skills-*' \) 2>/dev/null | sort)

  while IFS= read -r path; do
    remove_skill_link "$path"
  done < <(find "$CODEX_SKILLS_TARGET" -maxdepth 1 -type l \( -name 'pm-skills:*' -o -name 'pm-skills-*' \) 2>/dev/null | sort)

  remove_legacy_codex_namespace_if_owned
  remove_legacy_claude_plugin_if_present
  remove_local_configs

  echo "Removed"
  if [ "${#REMOVED_LINES[@]}" -gt 0 ]; then
    printf '%s\n' "${REMOVED_LINES[@]}"
  else
    echo "  None found"
  fi

  if [ "${#CONFIG_LINES[@]}" -gt 0 ]; then
    echo ""
    echo "Config"
    printf '%s\n' "${CONFIG_LINES[@]}"
  fi
}

main
