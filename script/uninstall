#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
PM_LOCAL="$HOME/.claude/pm-claude-skills.local.md"

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------
echo ""
echo "============================================"
echo "  PM Tools Uninstall"
echo "  Removes the pm-claude-skills plugin"
echo "============================================"
echo ""

# ---------------------------------------------------------------------------
# Prerequisites
# ---------------------------------------------------------------------------
if ! command -v claude &>/dev/null; then
  echo "Error: 'claude' CLI not found."
  exit 1
fi

# ---------------------------------------------------------------------------
# Step 1/2: Uninstall plugin + marketplace (Linear MCP auto-removed with it)
# ---------------------------------------------------------------------------
echo "[1/2] Uninstalling pm-claude-skills plugin..."
claude plugin uninstall pm-claude-skills >/dev/null 2>&1 || true
claude plugin marketplace remove pm-claude-skills >/dev/null 2>&1 || true
echo "      Done."

# ---------------------------------------------------------------------------
# Step 2/2: Personal config
# ---------------------------------------------------------------------------
echo ""
echo "[2/2] Personal configuration..."
if [ -f "$PM_LOCAL" ]; then
  read -rp "  Delete $PM_LOCAL? This contains your personal settings. (y/n) " CONFIRM
  if [[ "$CONFIRM" =~ ^[Yy] ]]; then
    rm "$PM_LOCAL"
    echo "      Deleted."
  else
    echo "      Kept."
  fi
else
  echo "      [skip] $PM_LOCAL not found."
fi

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------
echo ""
echo "Uninstalled. To reinstall: cd pm-claude-skills && script/setup"
echo ""
echo "Note: Optional integrations (Notion, Granola, etc.) were left in place."
echo "Remove them manually if no longer needed (claude plugin uninstall / claude mcp remove)."
echo ""
