#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
PROFILE_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/pm-skills/profile.md"
CLAUDE_COMMANDS_TARGET="$HOME/.claude/commands"
CLAUDE_COMMAND_WATERMARK="<!-- managed-by: pm-skills -->"
CODEX_SOURCE="$REPO_DIR/adapters/codex/pm-skills"
CODEX_TARGET="$HOME/.codex/skills/pm-skills"
FORCE="false"
SECTION_PRINTED="false"

SKILLS=(my-status team-status meeting-digest slack-recap shape-product-pitch make-decision)

ensure_namespaced_path() {
  local base
  base="$(basename "$1")"
  case "$base" in
  pm-skills | pm-skills:* | pm-skills-*) ;;
  *)
    echo "Refusing to manage non-namespaced path: $1" >&2
    exit 1
    ;;
  esac
}

assert_managed_paths_are_namespaced() {
  ensure_namespaced_path "$CODEX_TARGET"
  local skill
  for skill in "${SKILLS[@]}"; do
    ensure_namespaced_path "$CLAUDE_COMMANDS_TARGET/pm-skills:$skill.md"
  done
}

if [ "${1:-}" = "-f" ] || [ "${1:-}" = "--force" ]; then
  FORCE="true"
elif [ -n "${1:-}" ]; then
  echo "Usage: script/uninstall [-f|--force]"
  exit 1
fi

print_section() {
  if [ "$SECTION_PRINTED" = "true" ]; then
    echo ""
  fi
  echo "$1"
  SECTION_PRINTED="true"
}
display_path() {
  case "$1" in
  "$HOME") printf '~\n' ;;
  "$HOME"/*) printf '~/%s\n' "${1#"$HOME"/}" ;;
  *) printf '%s\n' "$1" ;;
  esac
}
abort_uninstall() {
  echo ""
  exit 130
}
trap abort_uninstall INT

command_file_owned() {
  [ -f "$1" ] && grep -Fxq "$CLAUDE_COMMAND_WATERMARK" "$1"
}

assert_managed_paths_are_namespaced

REMOVED_ANY="false"

if [ "$FORCE" != "true" ]; then
  read -r -p "Do you want to remove pm-skills? [y/N]: " CONFIRM_UNINSTALL || exit 130
  if [[ ! "$CONFIRM_UNINSTALL" =~ ^[Yy] ]]; then
    print_section "Done"
    echo "Nothing to remove"
    exit 0
  fi
fi

print_section "Claude Code"
CLAUDE_REMOVED="false"
for skill in "${SKILLS[@]}"; do
  local_file="$CLAUDE_COMMANDS_TARGET/pm-skills:$skill.md"
  if [ "$FORCE" = "true" ]; then
    [ -e "$local_file" ] && CLAUDE_REMOVED="true"
    rm -f "$local_file"
  elif command_file_owned "$local_file"; then
    rm -f "$local_file"
    CLAUDE_REMOVED="true"
  fi
done
if [ "$CLAUDE_REMOVED" = "true" ]; then
  echo "Removed pm-skills from Claude Code"
  REMOVED_ANY="true"
else
  echo "pm-skills not found in Claude Code"
fi

print_section "Codex"
if [ "$FORCE" = "true" ] && [ -e "$CODEX_TARGET" ]; then
  rm -rf "$CODEX_TARGET"
  echo "Removed pm-skills from Codex at $(display_path "$CODEX_TARGET")"
  REMOVED_ANY="true"
elif [ -L "$CODEX_TARGET" ]; then
  rm "$CODEX_TARGET"
  echo "Removed pm-skills from Codex at $(display_path "$CODEX_TARGET")"
  REMOVED_ANY="true"
else
  echo "pm-skills not found in Codex"
fi

print_section "Profile"
if [ -f "$PROFILE_PATH" ]; then
  if [ "$FORCE" = "true" ]; then
    rm "$PROFILE_PATH"
    echo "Removed pm-skills profile at $(display_path "$PROFILE_PATH")"
    REMOVED_ANY="true"
  else
    read -r -p "Delete $(display_path "$PROFILE_PATH")? [y/N]: " CONFIRM || exit 130
    if [[ "$CONFIRM" =~ ^[Yy] ]]; then
      rm "$PROFILE_PATH"
      echo "Removed pm-skills profile at $(display_path "$PROFILE_PATH")"
      REMOVED_ANY="true"
    else
      echo "Kept pm-skills profile at $(display_path "$PROFILE_PATH")"
    fi
  fi
else
  echo "pm-skills profile not found at $(display_path "$PROFILE_PATH")"
fi

print_section "Done"
if [ "$REMOVED_ANY" = "true" ]; then
  echo "pm-skills uninstall completed"
else
  echo "Nothing to remove"
fi
