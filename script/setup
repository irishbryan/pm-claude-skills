#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
PRIMARY_CONFIG_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/pm-skills/config.yml"
FALLBACK_CONFIG_PATH="$HOME/.pm-skills/config.yml"
CLAUDE_COMMANDS_TARGET="$HOME/.claude/commands"
CLAUDE_SKILLS_TARGET="$HOME/.claude/skills"
CODEX_SKILLS_TARGET="$HOME/.codex/skills"
LEGACY_CODEX_NAMESPACE="$HOME/.codex/skills/pm-skills"
MANAGED_COMMENT="<!-- managed-by: pm-skills repo=irishbryan/pm-skills -->"
LEGACY_MANAGED_COMMENT="<!-- managed-by: pm-skills -->"

display_path() {
  case "$1" in
    "$HOME") printf '~\n' ;;
    "$HOME"/*) printf '~/%s\n' "${1#"$HOME"/}" ;;
    *) printf '%s\n' "$1" ;;
  esac
}

config_path() {
  if [ -f "$PRIMARY_CONFIG_PATH" ]; then
    printf '%s\n' "$PRIMARY_CONFIG_PATH"
  elif [ -f "$FALLBACK_CONFIG_PATH" ]; then
    printf '%s\n' "$FALLBACK_CONFIG_PATH"
  elif mkdir -p "$(dirname "$PRIMARY_CONFIG_PATH")" 2>/dev/null; then
    printf '%s\n' "$PRIMARY_CONFIG_PATH"
  else
    mkdir -p "$(dirname "$FALLBACK_CONFIG_PATH")"
    printf '%s\n' "$FALLBACK_CONFIG_PATH"
  fi
}

canonical_path() {
  local path="$1"
  if [ -d "$path" ]; then
    (cd "$path" && pwd -P)
  else
    (cd "$(dirname "$path")" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$path")")
  fi
}

resolve_link_target() {
  local link_path="$1" raw_target="" combined_path=""
  raw_target="$(readlink "$link_path")" || return 1
  if [[ "$raw_target" = /* ]]; then
    if [ -e "$raw_target" ]; then
      canonical_path "$raw_target"
    else
      printf '%s\n' "$raw_target"
    fi
  else
    combined_path="$(cd "$(dirname "$link_path")" && pwd -P)/$raw_target"
    if [ -e "$combined_path" ]; then
      canonical_path "$combined_path"
    else
      printf '%s\n' "$combined_path"
    fi
  fi
}

skill_names() {
  find "$REPO_DIR/skills" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort
}

skill_source_dir() {
  printf '%s/skills/%s\n' "$REPO_DIR" "$1"
}

installed_skill_name() {
  printf 'pm-skills:%s\n' "$1"
}

extract_description() {
  awk -F': ' '/^description:/ {print $2; exit}' "$1"
}

is_managed_command_file() {
  [ -f "$1" ] && { grep -Fxq "$MANAGED_COMMENT" "$1" || grep -Fxq "$LEGACY_MANAGED_COMMENT" "$1"; }
}

is_owned_skill_target() {
  local path="$1" skill="$2"
  case "$path" in
    "$REPO_DIR/skills/$skill") return 0 ;;
    "$REPO_DIR/adapters/claude/skills/$skill") return 0 ;;
    "$REPO_DIR/plugins/pm-skills/skills/$skill") return 0 ;;
    "$REPO_DIR/adapters/codex/pm-skills/$skill") return 0 ;;
    *) return 1 ;;
  esac
}

remove_legacy_codex_namespace_if_owned() {
  local current_target=""
  if [ -L "$LEGACY_CODEX_NAMESPACE" ]; then
    current_target="$(resolve_link_target "$LEGACY_CODEX_NAMESPACE")"
    case "$current_target" in
      "$REPO_DIR/adapters/codex/pm-skills")
        rm "$LEGACY_CODEX_NAMESPACE"
        echo "Removed legacy Codex namespace $(display_path "$LEGACY_CODEX_NAMESPACE")"
        ;;
    esac
  fi
}

config_value() {
  local file_path="$1" key="$2"
  [ -f "$file_path" ] || return 0
  awk -F': ' -v key="$key" '$1 == "  " key {print $2; exit}' "$file_path"
}

prompt_with_default() {
  local prompt="$1" default_value="${2:-}" value=""
  read -r -p "$prompt: " value || exit 130
  printf '%s' "${value:-$default_value}"
}

write_config() {
  local file_path="$1" name="$2" email="$3" role="$4" team="$5" company="$6" product_area="$7" manager_name="$8" timezone="$9"
  mkdir -p "$(dirname "$file_path")"
  {
    printf 'profile:\n'
    if [ -n "$name" ]; then
      printf '  name: %s\n' "$name"
    fi
    if [ -n "$email" ]; then
      printf '  email: %s\n' "$email"
    fi
    if [ -n "$role" ]; then
      printf '  role: %s\n' "$role"
    fi
    if [ -n "$team" ]; then
      printf '  team: %s\n' "$team"
    fi
    if [ -n "$company" ]; then
      printf '  company: %s\n' "$company"
    fi
    if [ -n "$product_area" ]; then
      printf '  product_area: %s\n' "$product_area"
    fi
    if [ -n "$manager_name" ]; then
      printf '  manager_name: %s\n' "$manager_name"
    fi
    if [ -n "$timezone" ]; then
      printf '  timezone: %s\n' "$timezone"
    fi
  } >"$file_path"
}

write_claude_router() {
  local target_path="$CLAUDE_COMMANDS_TARGET/pm-skills.md"
  cat >"$target_path" <<EOF
---
description: Browse the installed pm-skills commands.
argument-hint: [skill name and optional context]
---

$MANAGED_COMMENT

Available commands:
$(skill_names | sed 's/^/- `\/pm-skills:/; s/$/`/')

If the first argument matches one of those skills, route the request there.
EOF
}

cleanup_legacy_skill_link() {
  local root="$1" skill="$2" legacy_path="" current_target=""
  legacy_path="$root/pm-skills-$skill"
  if [ -L "$legacy_path" ]; then
    current_target="$(resolve_link_target "$legacy_path")"
    if is_owned_skill_target "$current_target" "$skill"; then
      rm "$legacy_path"
    fi
  fi
}

sync_claude_router() {
  local target_path="$CLAUDE_COMMANDS_TARGET/pm-skills.md"
  if [ -e "$target_path" ] && [ ! -L "$target_path" ] && ! is_managed_command_file "$target_path"; then
    return
  fi
  write_claude_router
}

remove_managed_claude_skill_command() {
  local skill="$1" path=""
  for path in "$CLAUDE_COMMANDS_TARGET/pm-skills:$skill.md" "$CLAUDE_COMMANDS_TARGET/pm-skills-$skill.md"; do
    if [ -f "$path" ] && is_managed_command_file "$path"; then
      rm "$path"
    fi
  done
}

sync_skill_link() {
  local skill="$1" root="$2" target_path="" source_path="" current_target=""
  target_path="$root/$(installed_skill_name "$skill")"
  source_path="$(skill_source_dir "$skill")"

  if [ -L "$target_path" ]; then
    current_target="$(resolve_link_target "$target_path")"
    if [ "$current_target" = "$(canonical_path "$source_path")" ]; then
      printf 'ok\n'
      return
    fi
    if is_owned_skill_target "$current_target" "$skill"; then
      rm "$target_path"
      ln -s "$source_path" "$target_path"
      printf 'ok\n'
      return
    fi
    printf 'conflict\n'
    return
  fi

  if [ -e "$target_path" ]; then
    printf 'conflict\n'
    return
  fi

  ln -s "$source_path" "$target_path"
  printf 'ok\n'
}

main() {
  local config_file="" name="" email="" role="" team="" company="" product_area="" manager_name="" timezone="" skill="" claude_skill_status="" codex_skill_status="" status=""

  echo '╭────────────────────────────╮'
  echo '│         pm-skills          │'
  echo '╰────────────────────────────╯'
  echo ""

  config_file="$(config_path)"

  if [ -f "$config_file" ]; then
    echo "Personal context ($(display_path "$config_file"))"
    name="$(config_value "$config_file" name)"
    email="$(config_value "$config_file" email)"
    role="$(config_value "$config_file" role)"
    team="$(config_value "$config_file" team)"
    company="$(config_value "$config_file" company)"
    product_area="$(config_value "$config_file" product_area)"
    manager_name="$(config_value "$config_file" manager_name)"
    timezone="$(config_value "$config_file" timezone)"
    [ -n "$name" ] && printf '  name:         %s\n' "$name"
    [ -n "$email" ] && printf '  email:        %s\n' "$email"
    [ -n "$role" ] && printf '  role:         %s\n' "$role"
    [ -n "$team" ] && printf '  team:         %s\n' "$team"
    [ -n "$company" ] && printf '  company:      %s\n' "$company"
    [ -n "$product_area" ] && printf '  product_area: %s\n' "$product_area"
    [ -n "$manager_name" ] && printf '  manager:      %s\n' "$manager_name"
    [ -n "$timezone" ] && printf '  timezone:     %s\n' "$timezone"
    echo ""
    echo "  Edit $(display_path "$config_file") to update."
    echo ""
  else
    echo "To personalize experience, provide the following information."
    echo ""
    name="$(prompt_with_default "Your name (optional)" "")"
    email="$(prompt_with_default "Your work email (optional)" "")"
    team="$(prompt_with_default "Your team name (optional)" "")"
    role=""
    company=""
    product_area=""
    manager_name=""
    timezone=""
    write_config "$config_file" "$name" "$email" "$role" "$team" "$company" "$product_area" "$manager_name" "$timezone"
    echo ""
    echo "Config saved"
    echo "  $(display_path "$config_file")"
    echo ""
  fi

  mkdir -p "$CLAUDE_COMMANDS_TARGET" "$CLAUDE_SKILLS_TARGET" "$CODEX_SKILLS_TARGET"
  remove_legacy_codex_namespace_if_owned
  sync_claude_router

  echo "Skills"
  while IFS= read -r skill; do
    cleanup_legacy_skill_link "$CLAUDE_SKILLS_TARGET" "$skill"
    cleanup_legacy_skill_link "$CODEX_SKILLS_TARGET" "$skill"
    remove_managed_claude_skill_command "$skill"
    claude_skill_status="$(sync_skill_link "$skill" "$CLAUDE_SKILLS_TARGET")"
    codex_skill_status="$(sync_skill_link "$skill" "$CODEX_SKILLS_TARGET")"

    if [ "$claude_skill_status" = "conflict" ] || [ "$codex_skill_status" = "conflict" ]; then
      status="SKIP"
      printf '  %-4s %s (conflict)\n' "$status" "$skill"
    else
      status="OK"
      printf '  %-4s %s\n' "$status" "$skill"
    fi
  done < <(skill_names)

  echo ""
  echo "Next"
  echo "  Claude Code: /pm-skills:my-status"
  echo "  Codex:       \$pm-skills:my-status"
  echo ""
  echo "Tip"
  echo "  Connect MCPs like Linear, Slack, and Granola for better results."
}

main
