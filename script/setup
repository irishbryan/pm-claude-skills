#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
CONFIG_ROOT="${XDG_CONFIG_HOME:-$HOME/.config}/pm-skills"
PROFILE_PATH="$CONFIG_ROOT/profile.md"
CLAUDE_COMMANDS_TARGET="$HOME/.claude/commands"
CLAUDE_SKILLS_SOURCE="$REPO_DIR/plugins/pm-skills/skills"
CLAUDE_COMMAND_WATERMARK="<!-- managed-by: pm-skills -->"
LEGACY_PROFILE="$HOME/.claude/pm-claude-skills.local.md"
CLAUDE_SKILLS_TARGET="$HOME/.claude/skills"
CODEX_SOURCE="$REPO_DIR/adapters/codex/pm-skills"
CODEX_TARGET="$HOME/.codex/skills/pm-skills"
PROFILE_STATUS=""
CLAUDE_STATUS="not installed"
CODEX_STATUS="not installed"
HAS_CLAUDE="false"
LEGACY_PLUGIN_INSTALLED="false"
SECTION_PRINTED="false"
REFRESH_PROFILE="false"
PROFILE_ONLY="false"

SKILLS=(my-status team-status meeting-digest slack-recap shape-product-pitch make-decision)
SKILL_DESCRIPTIONS=(
  "Generate your personal status update"
  "Generate a team-wide status update"
  "Summarize recent meetings and extract action items"
  "Recap important Slack messages requiring attention"
  "Shape a product pitch using Shape Up methodology"
  "Draft a decision doc with a structured tradeoff table"
)
SKILL_ARG_HINTS=(
  "[time period]"
  "[time period]"
  "[topic or date range]"
  "[time period]"
  "[problem or idea]"
  "[decision or tradeoff]"
)

ensure_namespaced_path() {
  local base
  base="$(basename "$1")"
  case "$base" in
  pm-skills | pm-skills:* | pm-skills-*) ;;
  *)
    echo "Refusing to manage non-namespaced path: $1" >&2
    exit 1
    ;;
  esac
}

assert_managed_paths_are_namespaced() {
  ensure_namespaced_path "$CODEX_TARGET"
  local skill
  for skill in "${SKILLS[@]}"; do
    ensure_namespaced_path "$CLAUDE_COMMANDS_TARGET/pm-skills:$skill.md"
  done
}

usage() {
  cat <<'EOF'
Usage: script/setup [--refresh-profile] [--profile-only]

  --refresh-profile  Re-prompt and rewrite the shared profile
  --profile-only     Update only the shared profile and skip wrapper install
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
  --refresh-profile) REFRESH_PROFILE="true" ;;
  --profile-only)
    PROFILE_ONLY="true"
    REFRESH_PROFILE="true"
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  *)
    usage
    exit 1
    ;;
  esac
  shift
done

print_section() {
  if [ "$SECTION_PRINTED" = "true" ]; then
    echo ""
  fi
  echo "$1"
  SECTION_PRINTED="true"
}
trim() { printf '%s' "$1" | xargs; }
display_path() {
  case "$1" in
  "$HOME") printf '~\n' ;;
  "$HOME"/*) printf '~/%s\n' "${1#"$HOME"/}" ;;
  *) printf '%s\n' "$1" ;;
  esac
}
abort_setup() {
  echo ""
  exit 130
}
trap abort_setup INT

profile_value() {
  local file="$1" key="$2"
  [ -f "$file" ] || return 0
  awk -F': ' -v key="$key" '$0 ~ "^- " key ":" {print substr($0, index($0, ": ") + 2); exit}' "$file"
}

profile_section_list() {
  local file="$1" section="$2"
  [ -f "$file" ] || return 0
  awk -v section="$section" '
    $0 == "## " section {in_section=1; next}
    in_section && /^## / {exit}
    in_section && /^- / {
      item = substr($0, 3)
      if (length(item) > 0) items = items ? items ", " item : item
    }
    END {print items}
  ' "$file"
}

prompt_with_default() {
  local prompt="$1" default_value="${2:-}" value=""
  if [ -n "$default_value" ]; then
    read -r -p "$prompt [$default_value]: " value || exit 130
    printf '%s' "${value:-$default_value}"
  else
    read -r -p "$prompt: " value || exit 130
    printf '%s' "$value"
  fi
}

confirm_optional() {
  local reply=""
  read -r -p "$1 [y/N]: " reply || exit 130
  [[ "$reply" =~ ^[Yy] ]]
}

skill_symlink_path() {
  printf '%s/pm-skills-%s' "$CLAUDE_SKILLS_TARGET" "$1"
}

skill_symlink_owned() {
  local skill="$1"
  local path
  local target

  path="$(skill_symlink_path "$skill")"
  [ -L "$path" ] || return 1

  target="$(readlink "$path")"
  case "$target" in
  */plugins/pm-skills/skills/"$skill") return 0 ;;
  */plugins/pm-claude-skills/skills/"$skill") return 0 ;;
  *) return 1 ;;
  esac
}

detect_legacy_plugin() {
  if ! command -v claude >/dev/null 2>&1; then
    return
  fi

  HAS_CLAUDE="true"
  if claude plugin list 2>/dev/null | grep -q "^pm-claude-skills "; then
    LEGACY_PLUGIN_INSTALLED="true"
  fi
}

find_legacy_configuration() {
  local skill
  HAS_CLAUDE="false"
  LEGACY_PLUGIN_INSTALLED="false"
  LEGACY_FOUND_LINES=()

  detect_legacy_plugin
  if [ "$LEGACY_PLUGIN_INSTALLED" = "true" ]; then
    LEGACY_FOUND_LINES+=("Legacy Claude plugin: pm-claude-skills")
  fi

  if [ -f "$LEGACY_PROFILE" ]; then
    LEGACY_FOUND_LINES+=("Legacy profile: $(display_path "$LEGACY_PROFILE")")
  fi

  for skill in "${SKILLS[@]}"; do
    if skill_symlink_owned "$skill"; then
      LEGACY_FOUND_LINES+=("Legacy Claude skill symlink: $(display_path "$(skill_symlink_path "$skill")")")
    fi
  done
}

remove_legacy_plugin() {
  [ "$LEGACY_PLUGIN_INSTALLED" = "true" ] || return 0
  claude plugin uninstall pm-claude-skills >/dev/null 2>&1 || true
  claude plugin marketplace remove pm-claude-skills >/dev/null 2>&1 || true
  echo "Removed legacy Claude plugin and marketplace entry"
}

remove_legacy_skill_symlinks() {
  local skill
  local path

  for skill in "${SKILLS[@]}"; do
    if skill_symlink_owned "$skill"; then
      path="$(skill_symlink_path "$skill")"
      rm "$path"
      echo "Removed $(display_path "$path")"
    fi
  done
}

remove_legacy_profile() {
  [ -f "$LEGACY_PROFILE" ] || return 0

  read -r -p "Delete legacy profile at $(display_path "$LEGACY_PROFILE")? [y/N]: " DELETE_LEGACY_PROFILE || exit 130
  if [[ "$DELETE_LEGACY_PROFILE" =~ ^[Yy] ]]; then
    rm "$LEGACY_PROFILE"
    echo "Removed $(display_path "$LEGACY_PROFILE")"
  else
    echo "Kept legacy profile at $(display_path "$LEGACY_PROFILE")"
  fi
}

maybe_cleanup_legacy_configuration() {
  find_legacy_configuration

  if [ "${#LEGACY_FOUND_LINES[@]}" -eq 0 ]; then
    return
  fi

  print_section "Legacy configuration"
  for line in "${LEGACY_FOUND_LINES[@]}"; do
    echo "$line"
  done

  read -r -p "Clean up legacy configuration? [y/N]: " CLEANUP_LEGACY || exit 130
  if [[ ! "$CLEANUP_LEGACY" =~ ^[Yy] ]]; then
    echo "Skipped legacy configuration cleanup"
    return
  fi

  if [ "$HAS_CLAUDE" = "true" ]; then
    remove_legacy_plugin
  fi
  remove_legacy_skill_symlinks
  remove_legacy_profile

  echo "Legacy cleanup completed"
}

write_profile() {
  local name="$1" email="$2" focus="$3" teams="$4" slack_channels="$5"
  {
    printf '# pm-skills profile\n'
    printf '> Keep this file high-level. Avoid customer names, confidential project details, sensitive metrics, and exact roadmap dates.\n'
    printf '> Prefer broad themes, team names, channel names, and stakeholder roles.\n\n'
    printf -- '- Name: %s\n' "$name"
    printf -- '- Email: %s\n' "$email"
    printf -- '- Focus areas: %s\n' "$focus"
    if [ -n "$teams" ]; then
      printf '\n## Teams\n'
      IFS=',' read -ra TEAM_ARRAY <<<"$teams"
      for team in "${TEAM_ARRAY[@]}"; do
        team="$(trim "$team")"
        [ -n "$team" ] && printf -- '- %s\n' "$team"
      done
    fi
    if [ -n "$slack_channels" ]; then
      printf '\n## Slack\n'
      printf -- '- Main channels or groups: %s\n' "$slack_channels"
    fi
  } >"$PROFILE_PATH"
}

ensure_profile() {
  if [ -f "$PROFILE_PATH" ] && [ "$REFRESH_PROFILE" != "true" ]; then
    echo "pm-skills profile already exists at $(display_path "$PROFILE_PATH")"
    PROFILE_STATUS="$PROFILE_PATH"
    return
  fi

  mkdir -p "$CONFIG_ROOT"

  local defaults_file=""
  [ -f "$PROFILE_PATH" ] && defaults_file="$PROFILE_PATH"

  local default_name default_email default_focus default_teams default_slack
  default_name="$(profile_value "$defaults_file" "Name")"
  default_email="$(profile_value "$defaults_file" "Email")"
  default_focus="$(profile_value "$defaults_file" "Focus areas")"
  default_teams="$(profile_section_list "$defaults_file" "Teams")"
  default_slack="$(profile_value "$defaults_file" "Main channels or groups")"

  PM_NAME="$(prompt_with_default "Name" "$default_name")"
  PM_EMAIL="$(prompt_with_default "Email" "$default_email")"
  PM_FOCUS="$(prompt_with_default "Focus areas" "$default_focus")"

  PM_TEAMS=""
  if [ -n "$default_teams" ]; then
    PM_TEAMS="$(prompt_with_default "Teams (comma-separated, optional)" "$default_teams")"
  elif confirm_optional "Add teams?"; then
    PM_TEAMS="$(prompt_with_default "Teams (comma-separated)" "")"
  fi

  PM_SLACK_CHANNELS=""
  if [ -n "$default_slack" ]; then
    PM_SLACK_CHANNELS="$(prompt_with_default "What channels do you mainly work in? (optional)" "$default_slack")"
  elif confirm_optional "Add where you work in Slack day to day?"; then
    PM_SLACK_CHANNELS="$(prompt_with_default "What channels do you mainly work in?" "")"
  fi

  write_profile "$PM_NAME" "$PM_EMAIL" "$PM_FOCUS" "$PM_TEAMS" "$PM_SLACK_CHANNELS"
  echo "Saved pm-skills profile to $(display_path "$PROFILE_PATH")"
  PROFILE_STATUS="$PROFILE_PATH"
}

command_file_owned() {
  [ -f "$1" ] && grep -Fxq "$CLAUDE_COMMAND_WATERMARK" "$1"
}

write_claude_command() {
  local i="$1"
  local skill="${SKILLS[$i]}"
  local command_file="$CLAUDE_COMMANDS_TARGET/pm-skills:$skill.md"
  local skill_dir="$CLAUDE_SKILLS_SOURCE/$skill"

  cat >"$command_file" <<EOF
---
description: ${SKILL_DESCRIPTIONS[$i]}
argument-hint: ${SKILL_ARG_HINTS[$i]}
---

$CLAUDE_COMMAND_WATERMARK

Use the \`$skill\` workflow for this request.

Time/filter: \`\$ARGUMENTS\`.

Read @$skill_dir/instructions.md and @$skill_dir/templates/${skill}-template.md before generating output.
EOF
}

install_claude() {
  print_section "Claude Code"

  read -r -p "Install Claude Code wrapper? [y/N]: " INSTALL_CLAUDE || exit 130
  if [[ ! "$INSTALL_CLAUDE" =~ ^[Yy] ]]; then
    echo "Skipped installing pm-skills for Claude Code"
    CLAUDE_STATUS="skipped"
    return
  fi

  mkdir -p "$CLAUDE_COMMANDS_TARGET"

  local i skill command_file
  for i in "${!SKILLS[@]}"; do
    command_file="$CLAUDE_COMMANDS_TARGET/pm-skills:${SKILLS[$i]}.md"
    if [ -e "$command_file" ] && ! command_file_owned "$command_file"; then
      echo "Cannot install pm-skills for Claude Code because $(display_path "$command_file") is not managed by pm-skills"
      CLAUDE_STATUS="skipped"
      return
    fi
  done

  for i in "${!SKILLS[@]}"; do
    write_claude_command "$i"
  done

  echo "pm-skills installed for Claude Code at $(display_path "$CLAUDE_COMMANDS_TARGET")"
  CLAUDE_STATUS="installed"
}

install_codex() {
  print_section "Codex"

  if ! command -v codex >/dev/null 2>&1 && [ ! -d "$HOME/.codex" ]; then
    echo "Skipped installing pm-skills for Codex because Codex was not detected"
    CODEX_STATUS="unavailable"
    return
  fi

  read -r -p "Install Codex wrapper? [y/N]: " INSTALL_CODEX || exit 130
  if [[ ! "$INSTALL_CODEX" =~ ^[Yy] ]]; then
    echo "Skipped installing pm-skills for Codex"
    CODEX_STATUS="skipped"
    return
  fi

  mkdir -p "$(dirname "$CODEX_TARGET")"

  if [ -e "$CODEX_TARGET" ] && [ ! -L "$CODEX_TARGET" ]; then
    echo "Cannot install pm-skills for Codex because $(display_path "$CODEX_TARGET") is not a symlink"
    CODEX_STATUS="skipped"
    return
  fi

  [ -L "$CODEX_TARGET" ] && rm "$CODEX_TARGET"
  ln -s "$CODEX_SOURCE" "$CODEX_TARGET"
  echo "pm-skills installed for Codex at $(display_path "$CODEX_TARGET")"
  CODEX_STATUS="installed"
}

print_next_steps() {
  print_section "To get started:"
  [ "$CODEX_STATUS" = "installed" ] && echo "Codex: Type \$pm-skills"
  [ "$CLAUDE_STATUS" = "installed" ] && echo "Claude Code: Type /pm-skills"
  echo ""
  echo "For better results, connect MCPs like Granola, Slack, and Linear."
  echo "Setup complete."
}

print_profile_only_next_steps() {
  print_section "Setup complete"
  echo "Run script/setup to install wrappers"
}

assert_managed_paths_are_namespaced
maybe_cleanup_legacy_configuration
echo "Personalize skills (all data kept in local file):"
ensure_profile
if [ "$PROFILE_ONLY" = "true" ]; then
  print_profile_only_next_steps
  exit 0
fi
install_claude
install_codex
print_next_steps
